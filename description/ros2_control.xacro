<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!--
    Injects ROS 2 Control + Gazebo plugin for my_robot.
    You can override controller_yaml when calling the macro if needed.
  -->
    <!-- ros2_control hardware interface -->
    <ros2_control name="GazeboSystem" type="system">
      <hardware>
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </hardware>

      <!-- === Rear Left Wheel === -->
      <joint name="rear_left_wheel_joint">
        <command_interface name="velocity">
          <param name="min">-10.0</param>
          <param name="max"> 10.0</param>
        </command_interface>
        <state_interface name="velocity" />
        <state_interface name="position" />
      </joint>

      <!-- === Rear Right Wheel === -->
      <joint name="rear_right_wheel_joint">
        <command_interface name="velocity">
          <param name="min">-10.0</param>
          <param name="max"> 10.0</param>
        </command_interface>
        <state_interface name="velocity" />
        <state_interface name="position" />
      </joint>

      <!-- === Front Left Wheel === -->
      <joint name="front_left_wheel_joint">
        <command_interface name="velocity">
          <param name="min">-10.0</param>
          <param name="max"> 10.0</param>
        </command_interface>
        <state_interface name="velocity" />
        <state_interface name="position" />
      </joint>

      <!-- === Front Right Wheel === -->
      <joint name="front_right_wheel_joint">
        <command_interface name="velocity">
          <param name="min">-10.0</param>
          <param name="max"> 10.0</param>
        </command_interface>
        <state_interface name="velocity" />
        <state_interface name="position" />
      </joint>

    </ros2_control>
  <!-- Gazebo Sim plugin that loads controller parameters -->

  <gazebo>
    <plugin name="gz_ros2_control::GazeboSimROS2ControlPlugin"
      filename="libgz_ros2_control-system.so">
      <parameters>$(find my_robot)/config/my_controllers.yaml</parameters>
    </plugin>
  </gazebo>

</robot>